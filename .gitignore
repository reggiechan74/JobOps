# Node modules
node_modules/

# ============================================================
# Landing Pages - GitHub Pages Deployment
# ============================================================
# docs/ folder contains landing pages for GitHub Pages
# Note: docs/ is NOT gitignored - it's deployed to GitHub Pages

# JobOps workspace configuration (user-specific)
.jobops/

# Environment variables
.env
.env.local

# IDE and editor files
.vscode/*
!.vscode/settings.json
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# ============================================================
# JobOps v2.0 Output Directories
# ============================================================

# Applications/ - Per-application artifacts (resume, cover-letter, assessment, interview)
Applications/*
!Applications/.gitkeep
!Applications/README.md
!Applications/.example/

# Company_Intelligence/ - OSINT reports per company
Company_Intelligence/*
!Company_Intelligence/.gitkeep
!Company_Intelligence/README.md
!Company_Intelligence/.example/

# Career_Analysis/ - Flat timestamped career-level outputs
Career_Analysis/*
!Career_Analysis/.gitkeep
!Career_Analysis/README.md
!Career_Analysis/.example/

# Crisis_Management/ - Flat timestamped crisis-skill outputs
Crisis_Management/*
!Crisis_Management/.gitkeep
!Crisis_Management/README.md
!Crisis_Management/.example/

# Contractor/ - jobops-ic outputs
Contractor/*
!Contractor/.gitkeep
!Contractor/README.md
!Contractor/.example/

# ResumeSourceFolder/ - User's personal career inventory (gitignored)
ResumeSourceFolder/*
!ResumeSourceFolder/.gitkeep
!ResumeSourceFolder/README.md
!ResumeSourceFolder/.example/

# SourceMaterial/ - Ignore all files (analysis docs, personal artifacts)
SourceMaterial/*
!SourceMaterial/.gitkeep
!SourceMaterial/README.md

# Job_Postings/ - Track job postings, ignore automated search results
Job_Postings/SearchResults_*

# ============================================================
# Legacy v1.x directories (pre-2.0) — kept gitignored for any
# leftovers before `/jobops:migrate` is run on this workspace
# ============================================================
OutputResumes/
Scoring_Rubrics/
Briefing_Notes/
Intelligence_Reports/
Client_Prospects/

# ============================================================
# Document Conversion Outputs
# ============================================================

# Ignore converted Word documents (keep markdown source only)
*.docx

# ============================================================
# Logs and Temporary Files
# ============================================================

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temporary files
*.tmp
*.temp
.cache/

# ============================================================
# Notes for Contributors
# ============================================================
#
# What TO commit:
# - Templates (.template.md files)
# - Examples (files in .example/ directories)
# - Curated example job postings (Example_*.md)
# - Scoring rubrics (reusable assessment criteria)
# - Documentation and guides
# - System configuration files
#
# What NOT to commit:
# - Personal resume source materials
# - User-generated assessments (timestamp folders)
# - Personal job postings and search results
# - Generated briefing notes and intelligence reports
# - Converted Word documents (.docx)
#
# See CONTRIBUTING.md for detailed guidelines
#
